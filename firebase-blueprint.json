{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile including roles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["USER", "VENDOR", "ADMIN"] },
        "avatar": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace product details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category", "thumbnail", "vendorId", "vendorName"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "status": { "type": "string", "enum": ["PENDING", "PROCESSING", "SHIPPED", "DELIVERED", "CANCELLED"] },
        "totalAmount": { "type": "number" },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["PERCENTAGE", "FIXED"] },
        "discountValue": { "type": "number" },
        "minSpend": { "type": "number" },
        "expiryDate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Banner": {
      "title": "Banner",
      "description": "Hero slider banner",
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "link": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Hero banners"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    }
  }
}
